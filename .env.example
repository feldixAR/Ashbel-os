# ══════════════════════════════════════════════════════════════════
# AshbalOS — Environment Variables
# Copy this file to .env for local development.
# On Railway: set these via Dashboard → Variables or railway CLI.
# ══════════════════════════════════════════════════════════════════

# ── Database ───────────────────────────────────────────────────────
# Railway injects DATABASE_URL automatically when you add PostgreSQL.
# For local development use SQLite (default if not set):
#   DATABASE_URL=sqlite:///./data/ashbal_dev.db
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Auth ───────────────────────────────────────────────────────────
# API key required in X-API-Key header for every request (except /api/health)
API_KEY=change-this-to-a-strong-random-key

# Flask secret key — used for sessions
SECRET_KEY=change-this-to-a-strong-random-secret

# ── AI ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
OPENAI_API_KEY=sk-...   # optional — used as fallback model provider

# ── WhatsApp Business API ───────────────────────────────────────────
# Set after connecting Meta Business Manager
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ── Google Calendar (optional) ─────────────────────────────────────
# Without this, calendar events are created as deep links only
GOOGLE_CALENDAR_TOKEN=
GOOGLE_CALENDAR_ID=primary

# ── App ────────────────────────────────────────────────────────────
ENVIRONMENT=production
PORT=5000
LOG_LEVEL=INFO

# ── Autonomy ───────────────────────────────────────────────────────
# Actions at or above this risk level require human approval (1-5)
AUTO_APPROVE_BELOW_RISK=3

# ── Company (optional overrides) ───────────────────────────────────
# COMPANY_NAME=אשבל אלומיניום
# COMPANY_DOMAIN=עבודות אלומיניום
