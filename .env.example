# ══════════════════════════════════════════════════════════════════
# AshbelOS — Environment Variables
# Copy this file to .env for local development.
# On Railway: set these via Dashboard → Variables or railway CLI.
# See docs/DEPLOY.md for full deploy runbook.
# ══════════════════════════════════════════════════════════════════

# ── Database ───────────────────────────────────────────────────────
# Railway injects DATABASE_URL automatically when you add PostgreSQL.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Auth ───────────────────────────────────────────────────────────
# API key required in X-API-Key header for every request (except /api/health)
OS_API_KEY=Ashbel2026

# Flask secret key — used for sessions
SECRET_KEY=change-this-to-a-strong-random-secret

# ── AI ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Telegram (Wave One — only approved execution channel) ──────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
WEBHOOK_VERIFY_TOKEN=

# ── Business ───────────────────────────────────────────────────────
# Defaults to "ashbel" if unset. Do not change.
BUSINESS_ID=ashbel

# ── Lead Sources (stub mode when missing) ──────────────────────────
# Gmail listener: service account JSON
GMAIL_CREDENTIALS_JSON=
# Google Maps Places API key
GOOGLE_MAPS_API_KEY=

# ── App ────────────────────────────────────────────────────────────
ENVIRONMENT=production
PORT=5000
LOG_LEVEL=INFO

# ── Autonomy ───────────────────────────────────────────────────────
# Actions at or above this risk level require human approval (1-5)
AUTO_APPROVE_BELOW_RISK=3

# ── WhatsApp — BLOCKED (scaffold only, do not expand) ──────────────
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=

# ── Google Calendar — NOT APPROVED ─────────────────────────────────
# GOOGLE_CALENDAR_TOKEN=
# GOOGLE_CALENDAR_ID=primary
